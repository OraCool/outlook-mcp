%% AR Email Management - Email Category State Machine
%% Models how email categories transition across a thread's lifecycle.
%% 15 categories total. Transitions represent how the NEXT email in a thread
%% changes the thread's active category based on the reply content.
%%
%% Terminal states: ESCALATION_LEGAL, AUTO_REPLY, BILLING_UPDATE,
%%                  CREDIT_NOTE_REQUEST (issued), PAYMENT_CONFIRMATION (case closed)

stateDiagram-v2

    %% ════════════════════════════════════════════════
    %% Initial transitions — any new thread can start in these categories
    %% ════════════════════════════════════════════════

    [*] --> AUTO_REPLY : Auto-reply / OOO detected
    [*] --> PAYMENT_REMINDER_SENT : Outbound reminder sent
    [*] --> INVOICE_NOT_RECEIVED : Customer claims non-receipt
    [*] --> INVOICE_DISPUTE : Customer disputes charges
    [*] --> PAYMENT_PROMISE : Customer promises to pay
    [*] --> PAYMENT_CONFIRMATION : Customer confirms payment
    [*] --> EXTENSION_REQUEST : Customer requests extension
    [*] --> PARTIAL_PAYMENT_NOTE : Partial payment reported
    [*] --> ESCALATION_LEGAL : Legal language detected
    [*] --> REMITTANCE_ADVICE : Payment proof attached
    [*] --> BALANCE_INQUIRY : Customer asks about balance
    [*] --> CREDIT_NOTE_REQUEST : Customer requests credit note
    [*] --> BILLING_UPDATE : Contact or address change
    [*] --> INTERNAL_NOTE : Internal team communication
    [*] --> UNCLASSIFIED : Low confidence classification

    %% ════════════════════════════════════════════════
    %% PAYMENT_REMINDER_SENT transitions
    %% A reminder can trigger many different customer responses
    %% ════════════════════════════════════════════════

    PAYMENT_REMINDER_SENT --> INVOICE_NOT_RECEIVED : Customer says invoice not received
    PAYMENT_REMINDER_SENT --> PAYMENT_PROMISE : Customer promises to pay
    PAYMENT_REMINDER_SENT --> INVOICE_DISPUTE : Customer disputes amount
    PAYMENT_REMINDER_SENT --> PAYMENT_CONFIRMATION : Customer pays after reminder
    PAYMENT_REMINDER_SENT --> EXTENSION_REQUEST : Customer requests more time
    PAYMENT_REMINDER_SENT --> ESCALATION_LEGAL : Tone escalation / threat

    %% ════════════════════════════════════════════════
    %% INVOICE_NOT_RECEIVED transitions
    %% ════════════════════════════════════════════════

    INVOICE_NOT_RECEIVED --> PAYMENT_REMINDER_SENT : Invoice re-sent with new reminder

    %% ════════════════════════════════════════════════
    %% INVOICE_DISPUTE transitions
    %% Disputes can resolve, escalate, or lead to credit notes
    %% ════════════════════════════════════════════════

    INVOICE_DISPUTE --> CREDIT_NOTE_REQUEST : Dispute acknowledged, credit requested
    INVOICE_DISPUTE --> ESCALATION_LEGAL : Tone escalation / legal threat
    INVOICE_DISPUTE --> PAYMENT_PROMISE : Dispute resolved, payment agreed

    %% ════════════════════════════════════════════════
    %% PAYMENT_PROMISE transitions
    %% Promises can be fulfilled, broken, or partially met
    %% ════════════════════════════════════════════════

    PAYMENT_PROMISE --> PAYMENT_CONFIRMATION : Payment received as promised
    PAYMENT_PROMISE --> PAYMENT_REMINDER_SENT : Promise broken, follow-up reminder
    PAYMENT_PROMISE --> PARTIAL_PAYMENT_NOTE : Only partial amount received

    %% ════════════════════════════════════════════════
    %% EXTENSION_REQUEST transitions
    %% ════════════════════════════════════════════════

    EXTENSION_REQUEST --> PAYMENT_PROMISE : Extension granted, new date agreed
    EXTENSION_REQUEST --> PAYMENT_REMINDER_SENT : Extension denied, reminder issued

    %% ════════════════════════════════════════════════
    %% PARTIAL_PAYMENT_NOTE transitions
    %% ════════════════════════════════════════════════

    PARTIAL_PAYMENT_NOTE --> PAYMENT_REMINDER_SENT : Remaining balance reminder sent
    PARTIAL_PAYMENT_NOTE --> PAYMENT_CONFIRMATION : Full remaining balance received

    %% ════════════════════════════════════════════════
    %% UNCLASSIFIED transitions
    %% After human review, can become any category
    %% ════════════════════════════════════════════════

    UNCLASSIFIED --> PAYMENT_REMINDER_SENT : Reclassified after human review
    UNCLASSIFIED --> INVOICE_NOT_RECEIVED : Reclassified after human review
    UNCLASSIFIED --> INVOICE_DISPUTE : Reclassified after human review
    UNCLASSIFIED --> PAYMENT_PROMISE : Reclassified after human review
    UNCLASSIFIED --> PAYMENT_CONFIRMATION : Reclassified after human review
    UNCLASSIFIED --> EXTENSION_REQUEST : Reclassified after human review
    UNCLASSIFIED --> PARTIAL_PAYMENT_NOTE : Reclassified after human review
    UNCLASSIFIED --> ESCALATION_LEGAL : Reclassified after human review
    UNCLASSIFIED --> REMITTANCE_ADVICE : Reclassified after human review
    UNCLASSIFIED --> BALANCE_INQUIRY : Reclassified after human review
    UNCLASSIFIED --> CREDIT_NOTE_REQUEST : Reclassified after human review
    UNCLASSIFIED --> AUTO_REPLY : Reclassified after human review
    UNCLASSIFIED --> BILLING_UPDATE : Reclassified after human review
    UNCLASSIFIED --> INTERNAL_NOTE : Reclassified after human review

    %% ════════════════════════════════════════════════
    %% REMITTANCE_ADVICE and BALANCE_INQUIRY transitions
    %% ════════════════════════════════════════════════

    REMITTANCE_ADVICE --> PAYMENT_CONFIRMATION : Payment matched to invoice
    BALANCE_INQUIRY --> PAYMENT_REMINDER_SENT : Balance communicated with reminder

    %% ════════════════════════════════════════════════
    %% INTERNAL_NOTE transitions
    %% Internal notes can lead to outbound actions
    %% ════════════════════════════════════════════════

    INTERNAL_NOTE --> PAYMENT_REMINDER_SENT : Internal decision to send reminder
    INTERNAL_NOTE --> ESCALATION_LEGAL : Internal decision to escalate

    %% ════════════════════════════════════════════════
    %% Terminal states — handled outside the AI pipeline
    %% ════════════════════════════════════════════════

    ESCALATION_LEGAL --> [*] : Handled by legal / supervisor
    AUTO_REPLY --> [*] : No action needed
    BILLING_UPDATE --> [*] : Updated in SAP
    CREDIT_NOTE_REQUEST --> [*] : Credit note issued in SAP
    PAYMENT_CONFIRMATION --> [*] : Case closed — payment reconciled

    %% ════════════════════════════════════════════════
    %% Notes on terminal states
    %% ════════════════════════════════════════════════

    note right of ESCALATION_LEGAL
        Terminal for AI pipeline.
        Routed to legal team or supervisor.
        No automated response generated.
    end note

    note right of AUTO_REPLY
        Terminal. Auto-replies and OOO
        messages are logged and archived.
        No further processing.
    end note

    note right of PAYMENT_CONFIRMATION
        Terminal. Payment matched and
        reconciled in SAP. AR case closed.
    end note

    note left of BILLING_UPDATE
        Terminal. Contact or address
        change applied to SAP
        customer master data.
    end note

    note left of CREDIT_NOTE_REQUEST
        Terminal once credit note
        is issued. May reopen if
        customer disputes the credit.
    end note

    note right of UNCLASSIFIED
        Requires human review.
        Can transition to ANY
        other category once
        manually classified.
    end note
