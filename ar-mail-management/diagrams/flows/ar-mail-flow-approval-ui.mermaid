%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#4A90D9', 'primaryTextColor': '#ffffff', 'primaryBorderColor': '#2C6FAC', 'lineColor': '#1a1a1a', 'secondaryColor': '#f0f4f8', 'tertiaryColor': '#e8f4f8', 'signalColor': '#1a1a1a', 'signalTextColor': '#1a1a1a', 'activationBkgColor': '#d4e9f7'}}}%%
%% AR Email Management - Human Approval Interaction Sequence
%% Shows the full sequence from email submission through AI processing
%% to the four possible human review outcomes: Approve, Edit+Approve, Reject, Escalate.
%% The workflow PAUSES after ReviewPresenter and resumes on human action.

sequenceDiagram
    autonumber

    participant Bridge as Email Ingestion Service
    participant CM as CodeMie Workflow
    participant Classifier as EmailClassifier Agent
    participant Summarizer as ThreadSummarizer Agent
    participant Drafter as ResponseDrafter Agent
    participant Router as ActionRouter Agent
    participant Presenter as ReviewPresenter Agent
    participant UI as Approval UI<br/>(Alevate / SAP)
    participant AR as AR Specialist
    participant SAP as SAP FS2/S4
    participant Outlook as Microsoft Outlook
    participant Audit as Audit Store

    %% ── Email submission ──
    Bridge->>CM: Submit email for processing (email content + metadata)
    activate CM

    %% ── Thread summarization ──
    CM->>Summarizer: Summarize thread history
    Summarizer-->>CM: {thread_summary, email_count}

    %% ── Classification ──
    CM->>Classifier: Classify email (context package injected)
    Classifier-->>CM: {category, confidence, intent, reasoning}
    CM->>Audit: Log classification result

    %% ── Response drafting ──
    CM->>Drafter: Generate response draft (category + context + SAP templates)
    Drafter-->>CM: {draft_text, template_used, tone, suggested_subject}
    CM->>Audit: Log draft generated

    %% ── Action routing ──
    CM->>Router: Determine action (category + intent + customer data)
    Router-->>CM: {action_type, sap_transaction, parameters}

    %% ── Review packaging ──
    CM->>Presenter: Format review package
    Presenter-->>CM: {review_package: draft, context, actions, confidence}

    %% ── Workflow pauses for human review ──
    Note over CM: Workflow PAUSED — awaiting human decision
    CM->>UI: Push review package to approval queue
    deactivate CM

    UI->>AR: Display item in approval dashboard

    %% ── Four possible outcomes ──
    alt Approve as-is
        AR->>UI: Click "Approve"
        UI->>CM: Resume workflow (decision=APPROVED)
        activate CM
        CM->>Outlook: Send approved email via Graph API
        CM->>SAP: Update AR records (post correspondence, update status)
        CM->>Audit: Log approval (specialist_id, timestamp, decision=APPROVED)
        deactivate CM

    else Edit and Approve
        AR->>UI: Edit draft text / subject / recipients
        AR->>UI: Click "Approve" (edited version)
        UI->>CM: Resume workflow (decision=EDITED, edited_content)
        activate CM
        CM->>Outlook: Send edited email via Graph API
        CM->>SAP: Update AR records
        CM->>Audit: Log edit + approval (original_hash, edited_hash, diff_summary)
        deactivate CM

    else Reject
        AR->>UI: Click "Reject" with reason
        UI->>CM: Resume workflow (decision=REJECTED, reason)
        activate CM
        Note over CM: Email remains unactioned — no reply sent
        CM->>Audit: Log rejection (specialist_id, reason, category)
        deactivate CM

    else Escalate to supervisor
        AR->>UI: Click "Escalate" with notes
        UI->>CM: Resume workflow (decision=ESCALATED, notes, target_role)
        activate CM
        CM->>UI: Re-queue to supervisor's dashboard
        CM->>Audit: Log escalation (from_specialist, to_supervisor, notes)
        deactivate CM
    end
