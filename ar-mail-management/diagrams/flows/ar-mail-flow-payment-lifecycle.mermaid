%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#4A90D9', 'primaryTextColor': '#ffffff', 'primaryBorderColor': '#2C6FAC', 'lineColor': '#1a1a1a', 'secondaryColor': '#f0f4f8', 'tertiaryColor': '#e8f4f8', 'signalColor': '#1a1a1a', 'signalTextColor': '#1a1a1a', 'activationBkgColor': '#d4e9f7'}}}%%
%% AR Email Management - Payment Lifecycle Flows
%% End-to-end sequences for all payment-related scenarios:
%%   S1  / PAYMENT_REMINDER_SENT  — outbound follow-up reminder
%%   S3  / PAYMENT_PROMISE        — customer commits to pay by date
%%   S5  / PARTIAL_PAYMENT_NOTE   — customer reports partial payment
%%   S7  / PAYMENT_CONFIRMATION   — customer confirms payment sent
%%   S10 / REMITTANCE_ADVICE      — customer sends payment proof/reference
%%
%% Source: prompts/EmailClassifier.md, prompts/ResponseDrafter.md, prompts/ActionRouter.md

sequenceDiagram
    autonumber

    participant OL as Outlook<br/>(Graph API)
    participant ING as Email Ingestion<br/>Service
    participant TS as ThreadSummarizer
    participant EC as EmailClassifier
    participant RD as ResponseDrafter
    participant AR as ActionRouter
    participant RP as ReviewPresenter
    participant UI as Approval UI<br/>(Alevate / SAP)
    participant SAP as SAP FS2/S4
    participant AUD as Audit Store

    %% ════════════════════════════════════════════════
    %% Common Ingestion (shared by all payment scenarios)
    %% ════════════════════════════════════════════════
    Note over OL,AUD: Common Ingestion Phase

    OL->>ING: Webhook: new email notification
    ING->>OL: Fetch email content + metadata
    OL-->>ING: Email JSON (sender, subject, body, thread refs)
    ING->>TS: Summarize thread (if > 3 emails)
    TS-->>ING: Thread summary + key facts
    ING->>EC: Classify email (email + thread_summary + context)

    %% ════════════════════════════════════════════════
    %% S1 — Payment Reminder Sent (Outbound-Initiated)
    %% ════════════════════════════════════════════════
    alt S1 — PAYMENT_REMINDER_SENT (outbound follow-up)
        Note over EC: Category: PAYMENT_REMINDER_SENT<br/>Confidence: ~0.92<br/>Priority: HIGH (overdue)
        EC-->>ING: Classification result

        ING->>RD: Draft follow-up reminder
        Note over RD: Tone: FIRM<br/>Template: SAP payment reminder<br/>Include: invoice #, amount, days overdue
        RD-->>ING: Draft text (FIRM tone, ~138 words)

        ING->>AR: Route actions
        Note over AR: Actions:<br/>1. SEND_EMAIL(payment_reminder)<br/>Approval: STANDARD (4h)
        AR-->>ING: Action plan

        ING->>RP: Package for review
        RP-->>UI: Review package: draft + context + actions
        ING->>AUD: Log: classification + draft generated

        UI->>UI: AR Specialist reviews draft
        alt Approved
            UI->>OL: Send email via Graph API
            UI->>AUD: Log: approved + sent
        else Edit & Approve
            UI->>UI: Edit draft text
            UI->>OL: Send edited email via Graph API
            UI->>AUD: Log: edited + sent (edit hash)
        end

    %% ════════════════════════════════════════════════
    %% S3 — Payment Promise
    %% ════════════════════════════════════════════════
    else S3 — PAYMENT_PROMISE (customer commits to pay by date)
        Note over EC: Category: PAYMENT_PROMISE<br/>Sub-category: FIRM_COMMITMENT<br/>Confidence: ~0.96<br/>Priority: LOW<br/>Extracted: promised_date, invoice_numbers
        EC-->>ING: Classification result

        ING->>RD: Draft acknowledgement
        Note over RD: Tone: FORMAL<br/>Acknowledge commitment<br/>Confirm expected date
        RD-->>ING: Draft text (FORMAL tone)

        ING->>AR: Route actions
        Note over AR: Actions:<br/>1. UPDATE_SAP_DATE(expected_payment_date)<br/>2. LOG_EVENT(payment_promise_received)<br/>Approval: STANDARD (4h)
        AR-->>ING: Action plan

        Note over AR: Override Rule 5: If promised_date = null<br/>→ Skip UPDATE_SAP_DATE<br/>→ LOG_EVENT notes "date not specified"

        ING->>RP: Package for review
        RP-->>UI: Review package
        ING->>AUD: Log: classification + draft

        UI->>UI: AR Specialist reviews
        alt Approved
            UI->>SAP: UPDATE expected_payment_date
            SAP-->>UI: Confirmed
            UI->>SAP: LOG_EVENT: payment_promise_received
            UI->>OL: Send acknowledgement email
            UI->>AUD: Log: approved + SAP updated + sent
        end

    %% ════════════════════════════════════════════════
    %% S5 — Partial Payment Note
    %% ════════════════════════════════════════════════
    else S5 — PARTIAL_PAYMENT_NOTE (partial payment reported)
        Note over EC: Category: PARTIAL_PAYMENT_NOTE<br/>Confidence: ~0.88<br/>Priority: MEDIUM<br/>Extracted: payment_reference, invoice_numbers
        EC-->>ING: Classification result

        ING->>RD: Draft remaining balance notice
        Note over RD: Tone: FORMAL<br/>Acknowledge partial receipt<br/>State remaining balance
        RD-->>ING: Draft text (FORMAL tone)

        ING->>AR: Route actions
        Note over AR: Actions:<br/>1. TRIGGER_RECONCILIATION(partial_payment)<br/>2. LOG_EVENT(partial_payment_received)<br/>3. SEND_EMAIL(remaining_balance_notice)<br/>Approval: STANDARD (4h)<br/><br/>Override Rule 7: If multiple invoices<br/>→ separate TRIGGER_RECONCILIATION per invoice
        AR-->>ING: Action plan

        ING->>RP: Package for review
        RP-->>UI: Review package
        ING->>AUD: Log: classification + draft

        UI->>UI: AR Specialist reviews
        alt Approved
            UI->>SAP: TRIGGER_RECONCILIATION (per invoice)
            SAP-->>UI: Reconciliation initiated
            UI->>SAP: LOG_EVENT: partial_payment_received
            UI->>OL: Send remaining balance notice
            UI->>AUD: Log: approved + reconciliation + sent
        end

    %% ════════════════════════════════════════════════
    %% S7 — Payment Confirmation
    %% ════════════════════════════════════════════════
    else S7 — PAYMENT_CONFIRMATION (customer confirms payment sent)
        Note over EC: Category: PAYMENT_CONFIRMATION<br/>Confidence: ~0.90<br/>Priority: LOW<br/>Extracted: payment_reference (if provided)
        EC-->>ING: Classification result

        ING->>RD: Draft confirmation acknowledgement
        Note over RD: Tone: FORMAL<br/>Thank customer<br/>Confirm receipt processing
        RD-->>ING: Draft text (FORMAL tone)

        ING->>AR: Route actions
        Note over AR: Actions:<br/>1. TRIGGER_RECONCILIATION(full_payment)<br/>2. LOG_EVENT(payment_confirmation_received)<br/>Approval: STANDARD (4h)
        AR-->>ING: Action plan

        ING->>RP: Package for review
        RP-->>UI: Review package
        ING->>AUD: Log: classification + draft

        UI->>UI: AR Specialist reviews
        alt Approved
            UI->>SAP: TRIGGER_RECONCILIATION (full_payment)
            SAP-->>UI: Reconciliation initiated
            UI->>SAP: LOG_EVENT: payment_confirmation_received
            UI->>OL: Send acknowledgement
            UI->>AUD: Log: approved + reconciliation + sent
        end

    %% ════════════════════════════════════════════════
    %% S10 — Remittance Advice
    %% ════════════════════════════════════════════════
    else S10 — REMITTANCE_ADVICE (payment proof / bank reference)
        Note over EC: Category: REMITTANCE_ADVICE<br/>Confidence: ~0.93<br/>Priority: LOW<br/>Extracted: payment_reference,<br/>invoice_numbers, amounts
        EC-->>ING: Classification result

        ING->>RD: Draft remittance acknowledgement
        Note over RD: Tone: FORMAL<br/>Acknowledge receipt of remittance<br/>Confirm processing
        RD-->>ING: Draft text (FORMAL tone)

        ING->>AR: Route actions
        Note over AR: Actions:<br/>1. TRIGGER_RECONCILIATION(remittance_advice)<br/>2. LOG_EVENT(remittance_received)<br/>Approval: STANDARD (4h)
        AR-->>ING: Action plan

        ING->>RP: Package for review
        RP-->>UI: Review package
        ING->>AUD: Log: classification + draft

        UI->>UI: AR Specialist reviews
        alt Approved
            UI->>SAP: TRIGGER_RECONCILIATION (remittance_advice)
            Note over SAP: Match payment_reference<br/>against open items
            SAP-->>UI: Reconciliation initiated
            UI->>SAP: LOG_EVENT: remittance_received
            UI->>OL: Send acknowledgement
            UI->>AUD: Log: approved + reconciliation + sent
        end
    end
