%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#0078D4', 'primaryTextColor': '#ffffff', 'primaryBorderColor': '#005A9E', 'lineColor': '#2d2d2d', 'secondaryColor': '#f0f4f8', 'tertiaryColor': '#ffffff'}}}%%
%% AR Email Management - Action Routing Matrix
%% Maps each classified email category to its action plan, override rules,
%% and approval route tier. Source of truth for ActionRouter agent logic.
%% Source: prompts/ActionRouter.md, decisions/ADR-002

 flowchart TD

    %% ════════════════════════════════════════════════
    %% ENTRY
    %% ════════════════════════════════════════════════
    START(["Classified email arrives<br/>category + extracted_data<br/>+ has_draft_response"]) --> OVERRIDE_CHECK

    %% ════════════════════════════════════════════════
    %% SUBGRAPH: Override Rules (checked before routing)
    %% ════════════════════════════════════════════════
    subgraph overrides["Override Rules (Pre-Routing Checks)"]
        OVERRIDE_CHECK{"Override Rule 1:<br/>Category =<br/>ESCALATION_LEGAL?"}
        OVERRIDE_CHECK -- "Yes" --> OR1["Strip ALL actions<br/>except ESCALATE<br/>No SEND_EMAIL, No LOG_DISPUTE"]
        OR1 --> ROUTE_LEGAL

        OVERRIDE_CHECK -- "No" --> OR2{"Override Rule 2:<br/>Category =<br/>UNCLASSIFIED?"}
        OR2 -- "Yes" --> OR2_OUT["Strip ALL actions<br/>except ESCALATE<br/>No SEND_EMAIL"]
        OR2_OUT --> ROUTE_SUPER

        OR2 -- "No" --> OR3{"Override Rule 3:<br/>has_draft_response<br/>= false?"}
        OR3 -- "Yes" --> OR3_OUT["Remove SEND_EMAIL<br/>from action list<br/>Add LOG_EVENT noting<br/>no draft generated"]
        OR3_OUT --> CATEGORY_SWITCH

        OR3 -- "No" --> OR6{"Override Rule 6:<br/>Amount ><br/>EUR 100,000?"}
        OR6 -- "Yes" --> OR6_OUT["Upgrade approval_route<br/>to SUPERVISOR minimum"]
        OR6_OUT --> CATEGORY_SWITCH

        OR6 -- "No" --> CATEGORY_SWITCH
    end

    %% ════════════════════════════════════════════════
    %% SUBGRAPH: Category-to-Action Mapping (15 branches)
    %% ════════════════════════════════════════════════
    subgraph routing["Category → Action Mapping"]
        CATEGORY_SWITCH{"Route by<br/>category"}

        %% ── Payment Lifecycle ──
        CATEGORY_SWITCH -- "PAYMENT_REMINDER_SENT" --> ACT_PRS["1. SEND_EMAIL<br/>   response_type: payment_reminder"]
        ACT_PRS --> ROUTE_STD_PRS["STANDARD (4h)"]

        CATEGORY_SWITCH -- "PAYMENT_PROMISE" --> PP_CHECK{"Override Rule 5:<br/>promised_date<br/>= null?"}
        PP_CHECK -- "Yes — no date" --> ACT_PP_NODATE["1. LOG_EVENT<br/>   payment_promise_received<br/>   (date not specified)"]
        PP_CHECK -- "No — date present" --> ACT_PP["1. UPDATE_SAP_DATE<br/>   expected_payment_date<br/>2. LOG_EVENT<br/>   payment_promise_received"]
        ACT_PP_NODATE --> ROUTE_STD_PP["STANDARD (4h)"]
        ACT_PP --> ROUTE_STD_PP

        CATEGORY_SWITCH -- "PAYMENT_CONFIRMATION" --> ACT_PC["1. TRIGGER_RECONCILIATION<br/>   type: full_payment<br/>2. LOG_EVENT<br/>   payment_confirmation_received"]
        ACT_PC --> ROUTE_STD_PC["STANDARD (4h)"]

        CATEGORY_SWITCH -- "PARTIAL_PAYMENT_NOTE" --> PPN_CHECK{"Override Rule 7:<br/>Multiple invoices?"}
        PPN_CHECK -- "Yes" --> ACT_PPN_MULTI["Per invoice:<br/>1. TRIGGER_RECONCILIATION<br/>   type: partial_payment<br/>Shared:<br/>2. LOG_EVENT<br/>3. SEND_EMAIL<br/>   remaining_balance_notice"]
        PPN_CHECK -- "No" --> ACT_PPN["1. TRIGGER_RECONCILIATION<br/>   type: partial_payment<br/>2. LOG_EVENT<br/>   partial_payment_received<br/>3. SEND_EMAIL<br/>   remaining_balance_notice"]
        ACT_PPN_MULTI --> ROUTE_STD_PPN["STANDARD (4h)"]
        ACT_PPN --> ROUTE_STD_PPN

        CATEGORY_SWITCH -- "REMITTANCE_ADVICE" --> ACT_RA["1. TRIGGER_RECONCILIATION<br/>   type: remittance_advice<br/>2. LOG_EVENT<br/>   remittance_received"]
        ACT_RA --> ROUTE_STD_RA["STANDARD (4h)"]

        %% ── Invoice Lifecycle ──
        CATEGORY_SWITCH -- "INVOICE_NOT_RECEIVED" --> ACT_INR["1. SEND_EMAIL<br/>   response_type: invoice_resend<br/>2. LOG_EVENT<br/>   invoice_resent"]
        ACT_INR --> ROUTE_STD_INR["STANDARD (4h)"]

        CATEGORY_SWITCH -- "INVOICE_DISPUTE" --> ID_CHECK{"Override Rule 4:<br/>invoice_numbers<br/>empty?"}
        ID_CHECK -- "Yes" --> ACT_ID_NOINV["1. LOG_DISPUTE<br/>   invoice: UNKNOWN —<br/>   manual lookup required<br/>2. SEND_EMAIL<br/>   dispute_acknowledgement"]
        ID_CHECK -- "No" --> ID_MULTI{"Override Rule 7:<br/>Multiple invoices?"}
        ID_MULTI -- "Yes" --> ACT_ID_MULTI["Per invoice:<br/>1. LOG_DISPUTE<br/>Shared:<br/>2. SEND_EMAIL<br/>   dispute_acknowledgement"]
        ID_MULTI -- "No" --> ACT_ID["1. LOG_DISPUTE<br/>   (SAP FIRST)<br/>2. SEND_EMAIL<br/>   dispute_acknowledgement"]
        ACT_ID_NOINV --> ROUTE_PRI_ID["PRIORITY (1h)"]
        ACT_ID_MULTI --> ROUTE_PRI_ID
        ACT_ID --> ROUTE_PRI_ID

        CATEGORY_SWITCH -- "CREDIT_NOTE_REQUEST" --> ACT_CNR["1. LOG_EVENT<br/>   credit_note_requested<br/>2. SEND_EMAIL<br/>   acknowledgement"]
        ACT_CNR --> ROUTE_SUPER_CNR["SUPERVISOR (30min)"]

        %% ── Administrative / Inquiry ──
        CATEGORY_SWITCH -- "EXTENSION_REQUEST" --> ACT_ER["1. LOG_EVENT<br/>   extension_requested<br/>2. SEND_EMAIL<br/>   extension_acknowledgement"]
        ACT_ER --> ROUTE_SUPER_ER["SUPERVISOR (30min)"]

        CATEGORY_SWITCH -- "BALANCE_INQUIRY" --> ACT_BI["1. SEND_EMAIL<br/>   response_type: balance_statement"]
        ACT_BI --> ROUTE_STD_BI["STANDARD (4h)"]

        CATEGORY_SWITCH -- "BILLING_UPDATE" --> ACT_BU["1. LOG_EVENT<br/>   billing_update_requested"]
        ACT_BU --> ROUTE_STD_BU["STANDARD (4h)"]

        %% ── Non-Actionable ──
        CATEGORY_SWITCH -- "AUTO_REPLY" --> ACT_AR["1. LOG_EVENT<br/>   auto_reply_received"]
        ACT_AR --> ROUTE_STD_AR["STANDARD (4h)"]

        CATEGORY_SWITCH -- "INTERNAL_NOTE" --> ACT_IN["1. NO_ACTION"]
        ACT_IN --> ROUTE_STD_IN["STANDARD (4h)"]
    end

    %% ════════════════════════════════════════════════
    %% SUBGRAPH: Escalation Routes (from override rules)
    %% ════════════════════════════════════════════════
    subgraph escalation_routes["Escalation Routes"]
        ROUTE_LEGAL["LEGAL (15min SLA)<br/>ESCALATE → legal_team"]
        ROUTE_SUPER["SUPERVISOR (30min SLA)<br/>ESCALATE → supervisor"]
    end

    %% ════════════════════════════════════════════════
    %% SUBGRAPH: Approval Route Assignment
    %% ════════════════════════════════════════════════
    subgraph approval_assignment["Approval Route Assignment"]
        direction LR
        APPROVE_NOTE["All actions have<br/>requires_approval = true<br/>(non-negotiable)"]

        STD_BOX["STANDARD<br/>4h SLA<br/>Routine actions"]
        PRI_BOX["PRIORITY<br/>1h SLA<br/>Dispute-related"]
        SUP_BOX["SUPERVISOR<br/>30min SLA<br/>Business judgment"]
        LEG_BOX["LEGAL<br/>15min SLA<br/>Legal/threats"]
    end

    %% Connect routes to approval boxes
    ROUTE_STD_PRS --> STD_BOX
    ROUTE_STD_PP --> STD_BOX
    ROUTE_STD_PC --> STD_BOX
    ROUTE_STD_PPN --> STD_BOX
    ROUTE_STD_RA --> STD_BOX
    ROUTE_STD_INR --> STD_BOX
    ROUTE_STD_BI --> STD_BOX
    ROUTE_STD_BU --> STD_BOX
    ROUTE_STD_AR --> STD_BOX
    ROUTE_STD_IN --> STD_BOX
    ROUTE_PRI_ID --> PRI_BOX
    ROUTE_SUPER_CNR --> SUP_BOX
    ROUTE_SUPER_ER --> SUP_BOX
    ROUTE_SUPER --> SUP_BOX
    ROUTE_LEGAL --> LEG_BOX

    STD_BOX --> QUEUE([Queue for human approval])
    PRI_BOX --> QUEUE
    SUP_BOX --> QUEUE
    LEG_BOX --> QUEUE

    %% ════════════════════════════════════════════════
    %% Styling
    %% ════════════════════════════════════════════════
    style overrides fill:#fff3e0,stroke:#ff9800,stroke-width:2px
    style routing fill:#e8f4fd,stroke:#2196f3,stroke-width:2px
    style escalation_routes fill:#fce4ec,stroke:#e91e63,stroke-width:2px
    style approval_assignment fill:#e8f5e9,stroke:#4caf50,stroke-width:2px
