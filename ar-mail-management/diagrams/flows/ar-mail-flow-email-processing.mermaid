%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#0078D4', 'primaryTextColor': '#ffffff', 'primaryBorderColor': '#005A9E', 'lineColor': '#2d2d2d', 'secondaryColor': '#f0f4f8', 'tertiaryColor': '#ffffff'}}}%%
%% End-to-end email processing: Path A webhook push, Path B UI/MCP pull. See ar-mail-flow-sap-ui-trigger.mermaid, ar-mail-flow-ui-trigger-mcp.mermaid.

flowchart TD

    %% ════════════════════════════════════════════════
    %% SUBGRAPH: Email Ingestion — Path A (Webhook Push)
    %% ════════════════════════════════════════════════
    subgraph ingestion["Email Ingestion — Path A: Webhook Push"]
        A1([New email arrives in Outlook]) --> A2[Graph API webhook fires]
        A2 --> A3[Email Ingestion Service receives notification]
        A3 --> A4[Fetch full email content + metadata via Graph API]
        A4 --> A5{Rule Engine Pre-Filter}

        %% Pre-filter catches trivial cases before AI processing
        A5 -- "Auto-reply / OOO detected" --> A6[Log as AUTO_REPLY]
        A6 --> A7[Archive — no further processing]
        A7 --> AUDIT_PRE[/Audit: pre-filter action/]

        A5 -- "Known template match" --> A8[Apply template-based handling]
        A8 --> AUDIT_PRE

        A5 -- "Requires AI processing" --> B1
    end

    %% ════════════════════════════════════════════════
    %% SUBGRAPH: Email Ingestion — Path B (SAP UI Pull)
    %% ════════════════════════════════════════════════
    subgraph sap_trigger["Email Ingestion — Path B: SAP UI Pull via MCP"]
        SAP_UI([SAP UI or Alevate UI\npasses message_id]) --> ORCH[CodeMie Orchestrator receives\nmessage_id + customer_id]
        ORCH --> MCP_FETCH["Orchestrator calls Outlook MCP:\nget_email(message_id)\nget_thread(thread_id)"]
        MCP_FETCH --> MCP_GRAPH["Outlook MCP to Graph API\nGET /users/mailbox/messages/msgId\nAuthorization: Bearer app-level-token"]
        MCP_GRAPH --> EMAIL_CTX["Email + thread stored in\nCodeMie context store:\nemail, email_body, thread_emails"]
        EMAIL_CTX --> B1
    end

    %% ════════════════════════════════════════════════
    %% SUBGRAPH: AI Processing Pipeline
    %% ════════════════════════════════════════════════
    subgraph pipeline["AI Processing Pipeline"]

        %% Thread context reconstruction
        B1[ThreadSummarizer: reconstruct thread context] --> B2{Thread > 3 emails?}
        B2 -- "Yes" --> B3[Generate thread summary]
        B3 --> B4[Assemble Context Package]
        B2 -- "No" --> B4
        B4 --> B5

        %% Classification
        B5[EmailClassifier: categorize email] --> B6["Output: category + confidence + intent"]
        B6 --> B7{Confidence >= 0.75?}

        %% Low-confidence path
        B7 -- "No — low confidence" --> B8[Mark as UNCLASSIFIED]
        B8 --> B9[Route directly to human for manual classification]
        B9 --> AUDIT_CLASS[/Audit: low-confidence escalation/]
        B9 --> D1

        %% Legal escalation — immediate path, skip drafting
        B7 -- "Yes" --> B10{Category = ESCALATION_LEGAL?}
        B10 -- "Yes — legal language detected" --> B11[Skip drafting — immediate escalation]
        B11 --> AUDIT_ESC[/Audit: legal escalation/]
        B11 --> D1

        %% Normal processing continues
        B10 -- "No" --> C1

        %% Response drafting
        C1[ResponseDrafter: generate reply using SAP templates + context] --> C2["Output: draft text + template used"]
        C2 --> C3

        %% Action routing
        C3[ActionRouter: determine SAP/Alevate action] --> C4["Output: action type + parameters"]
        C4 --> C5

        %% Review packaging
        C5[ReviewPresenter: format for human review] --> C6["Output: review package with draft, context, suggested actions"]
        C6 --> AUDIT_DRAFT[/Audit: draft generated/]
        C6 --> D1
    end

    %% ════════════════════════════════════════════════
    %% SUBGRAPH: Human Approval
    %% ════════════════════════════════════════════════
    subgraph approval["Human Approval"]
        D1[Queue review package in approval dashboard] --> D2[AR Specialist opens item in Alevate UI or SAP UI]
        D2 --> D3{Review Decision}

        D3 -- "Approve" --> E1
        D3 -- "Edit & Approve" --> D4[Specialist edits draft text]
        D4 --> E2
        D3 -- "Reject" --> D5[Specialist provides rejection reason]
        D5 --> AUDIT_REJ[/Audit: rejection + reason/]
        D3 -- "Escalate" --> D6[Route to supervisor or legal]
        D6 --> AUDIT_ESCALATE[/Audit: escalation/]
    end

    %% ════════════════════════════════════════════════
    %% SUBGRAPH: Action Execution
    %% ════════════════════════════════════════════════
    subgraph execution["Action Execution"]
        E1[Send approved email via Graph API] --> E3[Update SAP records]
        E2[Send edited email via Graph API] --> E3
        E3 --> E4[Mark case as actioned]
        E4 --> AUDIT_EXEC[/Audit: action executed/]
    end

    %% ════════════════════════════════════════════════
    %% Styling
    %% ════════════════════════════════════════════════
    style ingestion fill:#e8f4fd,stroke:#2196f3,stroke-width:2px
    style sap_trigger fill:#e8f0fe,stroke:#3f51b5,stroke-width:2px
    style pipeline fill:#fff3e0,stroke:#ff9800,stroke-width:2px
    style approval fill:#e8f5e9,stroke:#4caf50,stroke-width:2px
    style execution fill:#fce4ec,stroke:#e91e63,stroke-width:2px
