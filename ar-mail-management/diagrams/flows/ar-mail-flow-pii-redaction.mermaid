%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#D83B01', 'primaryTextColor': '#ffffff', 'primaryBorderColor': '#A02800', 'lineColor': '#2d2d2d', 'secondaryColor': '#fff0ec', 'tertiaryColor': '#ffffff'}}}%%
%% PII data flow through Outlook MCP Server (sampling + tool responses)
%% Related: ADR-006, ADR-007, data-privacy.md

flowchart TD
    subgraph msGraph ["Microsoft Graph"]
        GAPI["GET me/messages<br/>full PII in JSON"]
    end

    subgraph mcp ["Outlook MCP Server"]
        FETCH["GraphMailClient"]
        SAN["sanitize_email_json<br/>truncate strip HTML"]
        PII["PII_Redactor_Presidio<br/>PII_REDACTION_ENABLED"]
        WRAP["build_untrusted_email_user_text"]
        RESP["email_json_for_tool_response<br/>PII_RESPONSE_LEVEL"]
    end

    subgraph client ["MCP host"]
        SAMPLE["MCP_sampling<br/>Azure_OpenAI"]
        ORCH["Orchestrator_tool_JSON"]
    end

    GAPI --> FETCH
    FETCH --> SAN
    SAN --> PII
    PII -->|"to sampling only"| WRAP
    WRAP --> SAMPLE
    FETCH --> RESP
    RESP -->|"full minimal redacted"| ORCH
    SAMPLE --> ORCH
