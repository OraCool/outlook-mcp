# Transport: stdio | streamable-http
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000
# Stateless Streamable HTTP (horizontal scaling; sampling may be limited)
MCP_STATELESS_HTTP=false

# Optional: local testing without X-Graph-Token (never use in production)
GRAPH_DEV_TOKEN=

# Optional: application permissions fallback for dev/tests (client credentials).
# This is NOT the same as X-Graph-Token: app-only token from YOUR app registration.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Feature flags
ENABLE_WRITE_OPERATIONS=false

# FastMCP
FASTMCP_DEBUG=false
FASTMCP_LOG_LEVEL=INFO
