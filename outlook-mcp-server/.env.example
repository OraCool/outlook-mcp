# Transport: stdio | streamable-http
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000
# Stateless Streamable HTTP (horizontal scaling; sampling may be limited)
MCP_STATELESS_HTTP=false

# Optional: local testing without X-Graph-Token (never use in production)
GRAPH_DEV_TOKEN=

# Microsoft Graph HTTP timeout in seconds (default 30; lower helps MCP Inspector fail fast)
GRAPH_HTTP_TIMEOUT=30

# Max seconds to wait for MCP sampling/createMessage (avoids hanging if the client never answers, e.g. Inspector)
MCP_SAMPLING_TIMEOUT_SECONDS=120

# Feature flags
ENABLE_WRITE_OPERATIONS=false

# PII / GDPR (optional: Python 3.12+ recommended; pip install '.[pii]' + python -m spacy download en_core_web_sm)
# PII_REDACTION_ENABLED=false
# PII_REDACTION_STRATEGY=pseudonymize
# PII_ENTITIES=EMAIL_ADDRESS,PERSON,PHONE_NUMBER,IBAN_CODE,CREDIT_CARD,IP_ADDRESS,LOCATION
# full | minimal (strips body_content only, not PII-safe) | redacted (tool email: Presidio or deterministic fallback)
# PII_RESPONSE_LEVEL=full

# OAuth (browser login for streamable-http: /oauth/login → X-OAuth-Session header on MCP calls)
# In-memory sessions: single process only; not compatible with MCP_STATELESS_HTTP multi-instance without a shared store.
GRAPH_OAUTH_ENABLED=false
GRAPH_OAUTH_CLIENT_ID=
GRAPH_OAUTH_CLIENT_SECRET=
GRAPH_OAUTH_TENANT=common
GRAPH_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/oauth/callback
# Add MailboxSettings.Read if you use list_master_categories (Outlook master categories).
GRAPH_OAUTH_SCOPES=Mail.Read offline_access
# MSAL token cache file for device-code login (outlook-mcp-oauth-device) and optional stdio silent refresh
GRAPH_OAUTH_TOKEN_CACHE_PATH=

# FastMCP
FASTMCP_DEBUG=false
FASTMCP_LOG_LEVEL=INFO
