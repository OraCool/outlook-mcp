# LLM (required)
LLM_PROVIDER=openai
# openai | anthropic

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# MCP connection to outlook-mcp-server
# streamable_http | stdio
MCP_TRANSPORT=streamable_http

# When MCP_TRANSPORT=streamable_http (default FastMCP path)
MCP_URL=http://127.0.0.1:8000/mcp

# Optional: delegated Microsoft Graph access token (JWT), sent as X-Graph-Token to MCP.
# Not your OpenAI/Anthropic key. Usually no Microsoft client ID here — see README for how to obtain a token.
X_GRAPH_TOKEN=

# When MCP_TRANSPORT=stdio — shell-style command to start the server process
# Example: python -m outlook_mcp.server  (with outlook-mcp-server installed)
MCP_STDIO_COMMAND=outlook-mcp-server

# Agent context limits (avoid OpenAI 128k overflows from huge tool payloads)
# Run `uv run` from this directory so `.env` is loaded (relative path).
AGENT_MAX_LLM_INPUT_TOKENS=100000
AGENT_MAX_MESSAGE_CHARS=36000
# Shrink further if the chat model's token count still exceeds this (room for system + tool defs).
AGENT_HARD_INPUT_TOKEN_CEILING=110000

# --- Server-side feature flag (not a setting for this tester) ---
# The MCP server has ENABLE_WRITE_OPERATIONS (default: false).
# When enabled on the server, the agent can use: send_email, create_draft,
# mark_as_read, move_email, create_reply_draft, set_message_categories,
# apply_llm_category_to_email. Set ENABLE_WRITE_OPERATIONS=true in the
# *server's* .env to unlock these tools.
